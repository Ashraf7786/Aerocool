{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "baseUrl": ".",
    "paths": {
      "@/utils/*": [
        "./src/backend/utils/*"
      ],
      "@/lib/*": [
        "./src/backend/lib/*"
      ],
      "@/services/*": [
        "./src/backend/services/*"
      ],
      "@/components/*": [
        "./src/frontend/components/*"
      ],
      "@/context/*": [
        "./src/frontend/context/*"
      ],
      "@/assets/*": [
        "./src/frontend/assets/*"
      ],
      "@frontend/*": [
        "./src/frontend/*"
      ],
      "@backend/*": [
        "./src/backend/*"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
